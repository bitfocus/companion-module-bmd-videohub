{
	"$schema": "../node_modules/@companion-module/base/assets/manifest.schema.json",
	"type": "connection",
	"id": "bmd-videohub",
	"name": "bmd-videohub",
	"shortname": "videohub",
	"description": "",
	"version": "0.0.0",
	"license": "MIT",
	"repository": "git+https://github.com/bitfocus/companion-module-bmd-videohub.git",
	"bugs": "https://github.com/bitfocus/companion-module-bmd-videohub/issues",
	"maintainers": [
		{
			"name": "William Viker",
			"email": "william@bitfocus.io"
		}
	],
	"legacyIds": ["videohub"],
	"runtime": {
		"type": "node22",
		"api": "nodejs-ipc",
